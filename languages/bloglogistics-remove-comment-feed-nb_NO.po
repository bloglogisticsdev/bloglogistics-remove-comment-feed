msgid "Comment Feed Settings"
msgstr "Innstillinger for kommentarstrømmer"

msgid "Disable comment feeds"
msgstr "Deaktiver kommentarstrømmer"

msgid "Message shown for blocked comment feeds"
msgstr "Melding som vises for blokkerte kommentarstrømmer"

msgid "BlogLogistics Remove Comment Feed"
msgstr "BlogLogistics Remove Comment Feed"

msgid "Remove Comment Feed"
msgstr "Fjern kommentarstrøm"

msgid "BlogLogistics"
msgstr "BlogLogistics"

msgid "Use the BlogLogistics submenu items to manage installed BlogLogistics plugins."
msgstr "Bruk BlogLogistics-undermenyene til å administrere installerte BlogLogistics-utvidelser."

msgid "Remove comment feed links from your site and block direct access to comment feed URLs. Normal post feeds are not affected."
msgstr "Fjerner lenker til kommentarstrømmer fra nettstedet og blokkerer direkte tilgang til URL-er for kommentarstrømmer. Vanlige innleggsstrømmer påvirkes ikke."

msgid "Stop visitors and bots from accessing comment RSS/Atom feeds."
msgstr "Hindrer besøkende og roboter i å få tilgang til RSS/Atom-strømmer for kommentarer."

msgid "This message is shown only if someone manually visits a comment feed URL, such as /comments/feed/. It does not create a page and it does not add any new links to your site."
msgstr "Denne meldingen vises bare hvis noen manuelt besøker en URL for kommentarstrøm, for eksempel /comments/feed/. Den oppretter ikke en side og legger ikke til nye lenker på nettstedet."

msgid "Reset message to default"
msgstr "Tilbakestill meldingen til standard"

msgid "Restores the default message shown when someone visits a blocked comment feed URL."
msgstr "Gjenoppretter standardmeldingen som vises når noen besøker en blokkert URL for kommentarstrøm."

msgid "You do not have permission to access this page."
msgstr "Du har ikke tillatelse til å åpne denne siden."

msgid "Comment Feed Disabled"
msgstr "Kommentarstrøm deaktivert"

msgid "Comment feeds are not available on this website."
msgstr "Kommentarstrømmer er ikke tilgjengelige på dette nettstedet."
