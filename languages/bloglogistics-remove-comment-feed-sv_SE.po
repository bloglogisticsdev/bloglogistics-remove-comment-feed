msgid "Comment Feed Settings"
msgstr "Inställningar för kommentarsflöden"

msgid "Disable comment feeds"
msgstr "Inaktivera kommentarsflöden"

msgid "Message shown for blocked comment feeds"
msgstr "Meddelande för blockerade kommentarsflöden"

msgid "BlogLogistics Remove Comment Feed"
msgstr "BlogLogistics Remove Comment Feed"

msgid "Remove Comment Feed"
msgstr "Ta bort kommentarsflöde"

msgid "BlogLogistics"
msgstr "BlogLogistics"

msgid "Use the BlogLogistics submenu items to manage installed BlogLogistics plugins."
msgstr "Använd undermenyerna i BlogLogistics för att hantera installerade BlogLogistics-tillägg."

msgid "Remove comment feed links from your site and block direct access to comment feed URLs. Normal post feeds are not affected."
msgstr "Tar bort länkar till kommentarsflöden från webbplatsen och blockerar direkt åtkomst till URL:er för kommentarsflöden. Vanliga inläggsflöden påverkas inte."

msgid "Stop visitors and bots from accessing comment RSS/Atom feeds."
msgstr "Förhindrar besökare och bottar från att komma åt RSS/Atom-flöden för kommentarer."

msgid "This message is shown only if someone manually visits a comment feed URL, such as /comments/feed/. It does not create a page and it does not add any new links to your site."
msgstr "Detta meddelande visas bara om någon manuellt besöker en URL för kommentarsflöde, till exempel /comments/feed/. Det skapar ingen sida och lägger inte till några nya länkar på webbplatsen."

msgid "Reset message to default"
msgstr "Återställ meddelandet till standard"

msgid "Restores the default message shown when someone visits a blocked comment feed URL."
msgstr "Återställer standardmeddelandet som visas när någon besöker en blockerad URL för kommentarsflöde."

msgid "You do not have permission to access this page."
msgstr "Du har inte behörighet att komma åt den här sidan."

msgid "Comment Feed Disabled"
msgstr "Kommentarsflöde inaktiverat"

msgid "Comment feeds are not available on this website."
msgstr "Kommentarsflöden är inte tillgängliga på denna webbplats."
